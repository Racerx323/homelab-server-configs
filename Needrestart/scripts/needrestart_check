# Install as /etc/cron.d/needrestart_check; see Needrestart/README.md in the repository.

SHELL=/bin/bash

# Mailgun account
# MAILTO=system@theama.me
# RECIPIENT=system@theama.me

# Mailrise account
MAILTO=notify.failure@mailrise.xyz
RECIPIENT=notify@mailrise.xyz

# Run daily at 05:30 as root and skip overlapping executions. Capture routine
# output, and expose it to cron only when the command exits unsuccessfully.
30 5 * * * root needrestart_cron_output=$(/usr/bin/flock -n /run/lock/needrestart-check.lock /usr/local/sbin/needrestart.sh 2>&1); needrestart_cron_status=$?; if ((needrestart_cron_status != 0)); then if [[ -n "$needrestart_cron_output" ]]; then printf '\%s\n' "$needrestart_cron_output"; else printf 'needrestart check failed with exit status \%s (the lock may already be held).\n' "$needrestart_cron_status"; fi; fi; exit "$needrestart_cron_status"
